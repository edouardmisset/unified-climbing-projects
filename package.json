{
  "name": "climbing-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "backup": "NEXT_PUBLIC_CONVEX_URL=https://watchful-platypus-57.convex.cloud node src/scripts/backup-from-db.ts && vp fmt ./src/backup",
    "preseed": "vp run backup",
    "seed": "vp exec convex import --replace --table ascents ./src/backup/ascent-data.json && vp exec convex import --replace --table training ./src/backup/training-data.json",
    "seed:prod": "vp exec convex import --prod --replace --table ascents ./src/backup/ascent-data.json && vp exec convex import --prod --replace --table training ./src/backup/training-data.json",
    "format": "vp fmt ./src",
    "lint": "vp lint --fix ./src",
    "check": "vp check && vp run style:lint",
    "commitlint": "commitlint --edit",
    "dev": "next dev",
    "convex:dev": "vp exec convex dev",
    "convex:dashboard": "open -a \"Brave Browser\" \"https://dashboard.convex.dev/t/edouard-6ac94/unified-climbing-app/small-monitor-700\"",
    "preview": "vp run build && next start",
    "reset": "rm -f pnpm-lock.yaml && vp install --force",
    "spell": "cspell lint --no-progress --show-suggestions --show-context --locale 'en,fr' ./src/**/*.ts*",
    "start": "next start",
    "style:lint": "stylelint --fix 'src/**/*.css'",
    "test:unit": "vp test --reporter=dot",
    "test:unit:watch": "vp run test:unit --watch",
    "test:unit:ui": "vp run test:unit --ui",
    "test:unit:silent": "vp run test:unit --silent=passed-only",
    "test:e2e": "playwright test",
    "test:e2e:ui": "vp run test:e2e --ui",
    "test:all": "vp run test:unit:silent && vp run test:e2e",
    "fallow": "fallow",
    "validate": "vp run check && vp run test:all && vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/nextjs": "^6.39.2",
    "@clerk/themes": "^2.4.55",
    "@edouardmisset/array": "npm:@jsr/edouardmisset__array@^4.0.3",
    "@edouardmisset/date": "npm:@jsr/edouardmisset__date@^4.2.0",
    "@edouardmisset/math": "npm:@jsr/edouardmisset__math@^4.0.0",
    "@edouardmisset/object": "npm:@jsr/edouardmisset__object@^4.0.1",
    "@edouardmisset/text": "npm:@jsr/edouardmisset__text@^4.1.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "convex": "^1.42.2",
    "convex-helpers": "^0.1.120",
    "fallow": "^3.6.0",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.3.0",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-view-transitions": "^0.3.5",
    "nuqs": "^2.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-toastify": "^11.1.0",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@shopify/eslint-plugin": "^50.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "cspell": "^10.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "happy-dom": "^20.10.6",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@10.28.1",
  "ct3aMetadata": {
    "initVersion": "7.38.1"
  }
}
